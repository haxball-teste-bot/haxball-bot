# ────────────────────────────────────────────
#  HaxBall Headless Host — Configuração
# ────────────────────────────────────────────

# Token do HaxBall (obtenha em https://www.haxball.com/headlesstoken)
HAXBALL_TOKEN=seu_token_aqui

# ────── Supabase ──────
# URL do projeto Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
# Service Role Key (bypassa RLS — mantenha em segredo!)
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ────── Sala ──────
ROOM_NAME=Sala
ROOM_MAX_PLAYERS=12
ROOM_PUBLIC=true
ROOM_PASSWORD=3
